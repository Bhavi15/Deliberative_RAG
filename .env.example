# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant (local mode — no key needed; set URL/key for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding model (sentence-transformers model name or HF repo ID)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Retrieval
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.5

# Scoring weights (must sum to 1.0)
WEIGHT_TEMPORAL=0.35
WEIGHT_AUTHORITY=0.40
WEIGHT_GRAPH=0.25

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
