# Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# LLM models — two tiers to spread load
#   heavy: synthesis, claim extraction, factual judge
#   light: query analysis, conflict classification
LLM_MODEL_HEAVY=gemma4:e4b
LLM_MODEL_LIGHT=gemma4:e2b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Qdrant (local mode — no key needed; set URL/key for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding model (sentence-transformers model name or HF repo ID)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.5

# Scoring weights (must sum to 1.0)
WEIGHT_TEMPORAL=0.35
WEIGHT_AUTHORITY=0.40
WEIGHT_GRAPH=0.25

# Web search — Tavily API (https://tavily.com — free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx
TAVILY_MAX_RESULTS=5

# Deep research agent — max search/analysis iterations
DEEP_RESEARCH_MAX_ITERATIONS=5

# MCP server port (Model Context Protocol)
MCP_SERVER_PORT=8100

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
